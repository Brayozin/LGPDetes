meta {
  name: User Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{userEmail}}",
    "password": "{{userPassword}}"
  }
}

assert {
  $res.status: 200
}

docs {
  Cria a sessão do usuário final.

  Credenciais seed padrão:
  - `{{userEmail}}`
  - `{{userPassword}}`
}
